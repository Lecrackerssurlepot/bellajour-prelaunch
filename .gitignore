# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
.DS_Store

# Night perf session — local backup of original images (recoverable from main too)
/image-originals/

# Sources vidéo brutes du parcours S2 — conservées en local, jamais déployées
# (assets web = les .mp4 optimisés + covers .png commités à côté)
/public/images/prevente/parcours/*.mov
